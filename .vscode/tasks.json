{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: gcc.exe 编译main.c",
            "command": "C:/mingw64/bin/gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "-I",
                "d:/Python/pythonProject",
                "-finput-charset=UTF-8",
                "-fexec-charset=UTF-8",
                "d:/Python/pythonProject/main.c",
                "-o",
                "output/main.exe"
            ],
            "options": {
                "cwd": "d:/Python/pythonProject"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}